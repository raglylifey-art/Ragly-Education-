    <style>
        :root {
            --cloud-blue: #71c5ee;
            --logo-purple: #6a3093;
            --logo-teal: #00b4db;
            --woody-yellow: #f9d423;
            --toy-red: #e74c3c;
            --rex-green: #2ecc71;
            --bubbly-font: 'Cherry Bomb One', cursive;
        }

        /* ANIMATED CLOUD BACKGROUND */
        body {
            margin: 0;
            font-family: 'Quicksand', sans-serif;
            background-color: var(--cloud-blue);
            background-image: url('https://www.transparenttextures.com/patterns/clouds.png');
            color: #333;
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        /* BUBBLE NAV MENU */
        nav {
            background: rgba(255, 255, 255, 0.95);
            padding: 15px;
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: center;
            gap: 12px;
            backdrop-filter: blur(10px);
            border-bottom: 6px solid var(--woody-yellow);
        }

        nav a {
            text-decoration: none;
            color: white;
            font-family: var(--bubbly-font);
            padding: 12px 22px;
            border-radius: 50px;
            font-size: 0.9rem;
            transition: 0.3s;
            box-shadow: 0 4px 0px rgba(0,0,0,0.2);
        }

        .nav-blue { background: var(--logo-teal); }
        .nav-purple { background: var(--logo-purple); }
        .nav-red { background: var(--toy-red); }
        .nav-green { background: var(--rex-green); }

        nav a:hover { transform: translateY(-5px) rotate(3deg); }

        /* HEADER & LOGO */
        header {
            background: white;
            padding: 60px 20px;
            border-bottom: 12px solid var(--toy-red);
            text-align: center;
            border-radius: 0 0 50% 50% / 0 0 20% 20%;
        }

        .header-logo {
            max-width: 320px;
            height: auto;
            filter: drop-shadow(5px 5px 0px var(--woody-yellow));
        }

